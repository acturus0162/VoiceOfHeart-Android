# Normalize text files to LF across platforms.
* text=auto eol=lf

# Shell scripts and Gradle wrappers.
gradlew text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Android and JVM source/config files.
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Binary assets and build artifacts.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.pdf binary
*.zip binary
*.jar binary
*.aar binary
*.apk binary
*.aab binary
*.dex binary
*.so binary
*.jks binary
*.keystore binary
